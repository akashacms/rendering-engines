  },
  "dependencies": {
    "@asciidoctor/core": "^4.x",
    "ejs": "^6.x",
    "eta": "^4.6.x",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.x",
    "less": "^4.6.x",
    "liquidjs": "^10.27.x",
    "mahabhuta": "^0.9.x",
    "markdown-it": "^14.2.x",
    "nunjucks": "^3.2.x"
  },
  "overrides": {
    "rimraf@<4": "5.0.10",
    "glob@<9": "10.4.5",
