{
  "name": "@akashacms/renderers",
  "version": "0.9.12",
  "description": "Consolidated support for multiple website content rendering tools in Node.js",
  "author": "David Herron <david@davidherron.com>",
  "license": "ISC",
  "bugs": "https://github.com/akashacms/rendering-engines/issues",
  "repository": {
